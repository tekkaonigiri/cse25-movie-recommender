.idle":"2026-03-19T04:53:28.254892Z","shell.execute_reply.started":"2026-03-19T04:53:28.236595Z","shell.execute_reply":"2026-03-19T04:53:28.254035Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def compute_rmse(model, test_df):\n    predictions = test_df.apply(\n        lambda row: model.predict(row[\"userId\"], row[\"movieId\"]), axis=1\n    )\n    rmse = np.sqrt(((test_df[\"rating\"] - predictions) ** 2).mean())\n    return rmse","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:28.256079Z","iopub.execute_input":"2026-03-19T04:53:28.256407Z","iopub.status.idle":"2026-03-19T04:53:28.270047Z","shell.execute_reply.started":"2026-03-19T04:53:28.256369Z","shell.execute_reply":"2026-03-19T04:53:28.269265Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# --- Test RMSE (secondary metric) ---\nrmse = compute_rmse(model, test_df)\nprint(f\"\\nTest RMSE: {rmse:.4f}\")\n\n# --- Sample: top-10 recommendations for user 1 ---\nall_movies = small_df[\"movieId\"].unique()\nseen = set(train_df[train_df[\"userId\"] == 1][\"movieId\"])\nrecs = model.recommend_top_k(1, all_movies, seen, k=10)\n\nprint(\"\\nTop-10 recommendations for user 1:\")\nfor movieId, score in recs:\n    print(f\"  movie {movieId:>5}  predicted rating: {score:.3f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:28.271069Z","iopub.execute_input":"2026-03-19T04:53:28.271445Z","iopub.status.idle":"2026-03-19T04:53:28.52441Z","shell.execute_reply.started":"2026-03-19T04:53:28.271419Z","shell.execute_reply":"2026-03-19T04:53:28.523403Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Number. Content-Based Filtering\n\n### Jaccard Similarity Function\n\nCalculates the overlap between movie genres through the intersection between two unique genres.\n\n# user this for the qualitative evidence of report -- prove system can identify similar movies based on meta data (eg/ action or sci fi) rather than just user ratings\n\n\n### Recommendation Display Function\nGenerate final personalized output\n\n# what makes recommendation display function different from the precision@k????? is it just the visaulization\n### uhh, idk where that function even is, but i assume so. I think its so u alrent doing all the different math in one function, its split apart for easier debugging and displaying the successful output with this mehtod in the end.\n\n1. Filter out movies the user has already seen\n2. Use the model's learned latent factors to predict ratings for the remaining titles\n3. Sort the predictions\n4. Map the raw IDs back to human-readable titles and genres\n5. Create the professional Top 10 table required for your results section.","metadata":{}},{"cell_type":"code","source":"def jaccard_similarity(movie_id_1, movie_id_2, genre_df):\n    genres1 = set(genre_df.columns[genre_df.loc[movie_id_1] == 1])\n    genres2 = set(genre_df.columns[genre_df.loc[movie_id_2] == 1])\n    \n    intersection = len(genres1.intersection(genres2))\n    union = len(genres1.union(genres2))\n    \n    return intersection/union if union != 0 else 0","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:28.525466Z","iopub.execute_input":"2026-03-19T04:53:28.5258Z","iopub.status.idle":"2026-03-19T04:53:28.531563Z","shell.execute_reply.started":"2026-03-19T04:53:28.525761Z","shell.execute_reply":"2026-03-19T04:53:28.530718Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# find movies with similar genre vectors\ndef get_similar_genres(movie_id, genre_df, movies_df, top_n=5):\n    similarities = []\n    for other_id in genre_df.index:\n        if other_id == movie_id: continue\n        score = jaccard_similarity(movie_id, other_id, genre_df)\n        similarities.append((other_id, score))\n    \n    similarities.sort(key=lambda x: x[1], reverse=True)\n    # merge w movies_df to get titles\n    return [(m_id, movies_df[movies_df['movieId'] == m_id]['title'].values[0], s) for m_id, s in similarities[:top_n]]","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:28.532574Z","iopub.execute_input":"2026-03-19T04:53:28.532935Z","iopub.status.idle":"2026-03-19T04:53:28.547748Z","shell.execute_reply.started":"2026-03-19T04:53:28.53291Z","shell.execute_reply":"2026-03-19T04:53:28.546842Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"get_similar_genres(movie_id=1, genre_df=genre_df_onehot, movies_df=movies_df, top_n=10)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:28.548953Z","iopub.execute_input":"2026-03-19T04:53:28.549317Z","iopub.status.idle":"2026-03-19T04:53:30.760253Z","shell.execute_reply.started":"2026-03-19T04:53:28.549282Z","shell.execute_reply":"2026-03-19T04:53:30.75937Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def get_mf_similar_movies(movie_id, model, movies_df, k=10):\n    # Get the internal index for this movie\n    i = model.item_idx.get(movie_id)\n    if i is None:\n        return []\n    \n    # Compute cosine similarity between this movie and all others\n    sims = cosine_similarity([model.Q[i]], model.Q)[0]\n    \n    # Sort by similarity, excluding the movie itself\n    similar_indices = sims.argsort()[::-1]\n    results = []\n    for idx in similar_indices:\n        m_id = model.item_ids[idx]\n        if m_id == movie_id:\n            continue\n        title = movies_df[movies_df[\"movieId\"] == m_id][\"title\"].values[0]\n        results.append((m_id, title, sims[idx]))\n        if len(results) == k:\n            break\n    return results","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:30.761291Z","iopub.execute_input":"2026-03-19T04:53:30.761549Z","iopub.status.idle":"2026-03-19T04:53:30.768207Z","shell.execute_reply.started":"2026-03-19T04:53:30.761525Z","shell.execute_reply":"2026-03-19T04:53:30.767107Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def compare_mf_vs_jaccard(movie_id, model, genre_df_onehot, movies_df, k=10):\n    title = movies_df[movies_df[\"movieId\"] == movie_id][\"title\"].values[0]\n    print(f\"Query movie: {title}\\n\")\n\n    mf_recs = get_mf_similar_movies(movie_id, model, movies_df, k=k)\n    jaccard_recs = get_similar_genres(movie_id, genre_df_onehot, movies_df, top_n=k)\n\n    print(f\"{'MF Similar (latent factors)':<55} {'Jaccard Similar (genres)'}\")\n    print(\"-\" * 100)\n    for (m_id, mf_title, mf_score), (j_id, j_title, j_score) in zip(mf_recs, jaccard_recs):\n        print(f\"(id: {m_id:<6}) {mf_title:<55} (id: {j_id}) {j_title:<55}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:30.769511Z","iopub.execute_input":"2026-03-19T04:53:30.76983Z","iopub.status.idle":"2026-03-19T04:53:30.788631Z","shell.execute_reply.started":"2026-03-19T04:53:30.769803Z","shell.execute_reply":"2026-03-19T04:53:30.787829Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"compare_mf_vs_jaccard(movie_id=1, model=model, genre_df_onehot=genre_df_onehot, movies_df=movies_df, k=10)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:30.78975Z","iopub.execute_input":"2026-03-19T04:53:30.790447Z","iopub.status.idle":"2026-03-19T04:53:33.024465Z","shell.execute_reply.started":"2026-03-19T04:53:30.790386Z","shell.execute_reply":"2026-03-19T04:53:33.023587Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def plot_jaccard_heatmap(genre_df_onehot, movies_df, n_movies=20):\n    # Pick n_movies to display\n    sample_ids = list(genre_df_onehot.index[:n_movies])\n    sample_titles = [\n        movies_df[movies_df[\"movieId\"] == m][\"title\"].values[0]\n        for m in sample_ids\n    ]\n\n    # Build similarity matrix\n    sim_matrix = np.zeros((n_movies, n_movies))\n    for i, id1 in enumerate(sample_ids):\n        for j, id2 in enumerate(sample_ids):\n            sim_matrix[i][j] = jaccard_similarity(id1, id2, genre_df_onehot)\n\n    # Plot\n    plt.figure(figsize=(12, 10))\n    sns.heatmap(\n        sim_matrix,\n        xticklabels=sample_titles,\n        yticklabels=sample_titles,\n        cmap=\"YlOrRd\",\n        vmin=0, vmax=1\n    )\n    plt.title(\"Jaccard Genre Similarity Heatmap\")\n    plt.xticks(rotation=90)\n    plt.yticks(rotation=0)\n    plt.tight_layout()\n    plt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:33.02555Z","iopub.execute_input":"2026-03-19T04:53:33.02587Z","iopub.status.idle":"2026-03-19T04:53:33.033332Z","shell.execute_reply.started":"2026-03-19T04:53:33.025832Z","shell.execute_reply":"2026-03-19T04:53:33.032206Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"plot_jaccard_heatmap(genre_df_onehot, movies_df, n_movies=20)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:33.034539Z","iopub.execute_input":"2026-03-19T04:53:33.034912Z","iopub.status.idle":"2026-03-19T04:53:33.617143Z","shell.execute_reply.started":"2026-03-19T04:53:33.034871Z","shell.execute_reply":"2026-03-19T04:53:33.616011Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Number. Evaluate\n\n# {explain evaluation here + precision@10}","metadata":{}},{"cell_type":"code","source":"def precision_at_k(model, test_df, k=10, threshold=4.0):\n    \"\"\"\n    Precision@k: (number of recommended items that are relevant) / k\n    \n    - a movie is considered relevant if the user's actual rating is greater than\n        or equal to threshold\n\n    Process\n\n    1. Find all unique users in the test set. Sample 1000 users (since we're using such a\n        large database of 20M data)\n    2. Calculate the precision + for loop to show the progress bar\n            a. Get movies the user actually liked in the test set. Skip any users with\n                no liked movies\n            b. Get top-k recommendations.\n            c. Pass seen_movie_ids from the training set so we don't recommend what the user\n                has already seen\n            d. Calculate how many recommendations were actually in the 'true liked' list\n    3. Output score\n                \n    \"\"\"\n    precisions = []\n    test_users = test_df['userId'].unique()\n    all_movie_ids = model.item_ids\n    sample_users = np.random.choice(test_users, len(test_users), replace=False)\n\n    for u_id in tqdm(sample_users, desc=\"Calculating Precision@10\"):\n        user_test_data = test_df[test_df['userId'] == u_id]\n        true_liked_movies = set(user_test_data[user_test_data['rating'] >= threshold]['movieId'])\n        \n        if not true_liked_movies:\n            continue\n\n        # top-k recommendations\n        seen_train = set(train_df[train_df['userId'] == u_id]['movieId'])\n        recommendations = model.recommend_top_k(u_id, all_movie_ids, seen_train, k=k)\n        rec_ids = [m[0] for m in recommendations]\n\n        hits = len(set(rec_ids) & true_liked_movies)\n        precisions.append(hits / k)\n        \n    return np.mean(precisions)\n\nmodel_precision = precision_at_k(model, test_df)\nprint(f\"Matrix Factorization Precision@10: {model_precision:.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:33.618209Z","iopub.execute_input":"2026-03-19T04:53:33.618527Z","iopub.status.idle":"2026-03-19T04:53:41.753541Z","shell.execute_reply.started":"2026-03-19T04:53:33.618494Z","shell.execute_reply":"2026-03-19T04:53:41.752666Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Number. Benchmarks\nWe compare the model's output to two baselines: popularity and random.\n\nThe popularity baseline shows what occurs if the model just recommends only the highest-rated movies globally. The random baseline shows the worst-case scenario where the model is guessing blindly.\n\nThe two baselines prove that our model is mathematically more insightful than simply random guessing or relying on global hits. By outperforming these, the matrix factorization has successfully learned latent patterns to provide truly personalized recommendations for individual users.","metadata":{}},{"cell_type":"code","source":"\"\"\"\nPOPULARITY BASELINE\n\nFind the global top-k and compare it to what the specific user liked\n\"\"\"\n\ntop_10_popular = train_df.groupby('movieId').size().nlargest(10).index.tolist()\n\ndef popularity_baseline_precision(test_df, popular_ids, k=10, threshold=4.0):\n    precisions = []\n    test_users = test_df['userId'].unique()\n    sample_users = np.random.choice(test_users, len(test_users), replace=False)\n\n    for u_id in sample_users:\n        user_test_data = test_df[test_df['userId'] == u_id]\n        true_liked = set(user_test_data[user_test_data['rating'] >= threshold]['movieId'])\n        \n        if not true_liked:\n            continue\n\n        hits = len(set(popular_ids) & true_liked)\n        precisions.append(hits / k)\n\n    return np.mean(precisions)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:41.754667Z","iopub.execute_input":"2026-03-19T04:53:41.754933Z","iopub.status.idle":"2026-03-19T04:53:41.766852Z","shell.execute_reply.started":"2026-03-19T04:53:41.754909Z","shell.execute_reply":"2026-03-19T04:53:41.765916Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"\"\"\"\nRANDOM BASELINE\n\nPick k movies at random from the entire catalog for every user,\n    then compare it to what the specific user liked.\n\"\"\"\n\nall_movie_ids = ratings_df['movieId'].unique()\n\ndef random_baseline_precision(test_df, all_ids, k=10, threshold=4.0):\n    precisions = []\n    test_users = test_df['userId'].unique()\n    sample_users = np.random.choice(test_users, len(test_users), replace=False)\n    \n    for u_id in sample_users:\n        user_test = test_df[test_df['userId'] == u_id]\n        true_liked = set(user_test[user_test['rating'] >= threshold]['movieId'])\n        \n        if not true_liked: \n            continue\n\n        random_recs = np.random.choice(all_ids, k, replace=False)\n        hits = len(set(random_recs) & true_liked)\n        precisions.append(hits / k)\n\n    return np.mean(precisions)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:41.768154Z","iopub.execute_input":"2026-03-19T04:53:41.768713Z","iopub.status.idle":"2026-03-19T04:53:41.786896Z","shell.execute_reply.started":"2026-03-19T04:53:41.76868Z","shell.execute_reply":"2026-03-19T04:53:41.785925Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# run popularity and random baselines as benchmark\nmodel_rmse = compute_rmse(model, test_df)\npop_precision = popularity_baseline_precision(test_df, top_10_popular)\nrand_precision = random_baseline_precision(test_df, all_movie_ids)\n\nmodel_precision = precision_at_k(model, test_df)\n\nprint(\"=== FINAL PERFORMANCE COMPARISON ===\")\nprint(f\"MF RMSE:                {model_rmse:.4f}\")\nprint(f\"Random Baseline Precision@10:      {rand_precision:.4f}\")\nprint(f\"Popularity Baseline Precision@10:  {pop_precision:.4f}\")\nprint(f\"Matrix Factorization Precision@10: {model_precision:.4f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-19T04:53:41.78799Z","iopub.execute_input":"2026-03-19T04:53:41.788278Z","iopub.status.idle":"2026-03-19T04:53:50.937562Z","shell.execute_reply.started":"2026-03-19T04:53:41.788253Z","shell.execute_reply":"2026-03-19T04:53:50.936614Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def plot_baseline_comparison(model_precision, pop_precision, rand_precision, model_rmse):\n    fig, ax = plt.subplots(figsize=(7, 4))\n\n    # Precision@10 bar chart\n    models = [\"MF\", \"Popularity\", \"Random\"]\n    precisions = [model_precision, pop_precision, rand_precision]\n    ax.bar(models, precisions, color=[\"steelblue\", \"salmon\", \"lightgray\"])\n    ax.set_title(\"Precision@1